# Groq API (for GPT-OSS-120B - schema mapping, reasoning)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b

# Ollama (for Qwen 3.5 0.8B - vision, local inference)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=qwen3.5:0.8b

# Storage paths
UPLOAD_DIR=storage/uploads
EXTRACTED_DIR=storage/extracted
PROFILES_DIR=storage/profiles
INDEX_DIR=storage/index
MEDIA_DIR=storage/media

# Processing settings
MAX_ZIP_SIZE_MB=500
MAX_CONCURRENT_PARSERS=4
LOG_LEVEL=INFO
